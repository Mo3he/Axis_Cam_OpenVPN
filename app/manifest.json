{
    "schemaVersion": "2.0.0",
    "acapPackageConf": {
        "setup": {
            "friendlyName": "OpenVPN VPN",
            "appName": "OpenVPN_VPN",
            "vendor": "moshe@mohome.net",
            "vendorId": "70ee172dd9",
            "vendorUrl": "https://github.com/Mo3he",
            "runMode": "respawn",
            "version": "0.1.1",
            "user": {
                "group": "sdk",
                "username": "sdk"
            },
            "architecture": "BUILDARCH",
            "compatibleOsVersions": [
                { "max": "13" }
            ]
        },
        "configuration": {
            "settingPage": "index.html",
            "reverseProxy": [
                {
                    "apiPath": "api",
                    "target": "http://localhost:2202/",
                    "access": "admin"
                }
            ],
            "paramConfig": [
                {"name": "Username",      "default": "",     "type": "string"},
                {"name": "Password",      "default": "",     "type": "string"},
                {"name": "HttpProxyPort", "default": "8080", "type": "string"},
                {"name": "Socks5Port",    "default": "1080", "type": "string"}
            ]
        }
    }
}
